<!DOCTYPE html>
<html lang="en">
<head>
  <%- include("./partials/head") %>
  <style>
    :root {
      --card-bg: rgba(255, 255, 255, 0.7);
      --card-blur: 20px;
    }

    .dashboard-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      grid-auto-rows: minmax(160px, auto);
      gap: 20px;
      margin-top: 40px;
    }

    .bento-card {
      background: var(--card-bg);
      backdrop-filter: blur(var(--card-blur));
      -webkit-backdrop-filter: blur(var(--card-blur));
      border: 1px solid var(--glass-border);
      border-radius: var(--radius-lg);
      padding: 2rem;
      transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .bento-card:hover {
      transform: translateY(-5px);
      box-shadow: var(--shadow-xl);
      border-color: var(--primary);
    }

    .stat-val {
      font-size: 3rem;
      font-weight: 900;
      line-height: 1;
      margin-bottom: 0.5rem;
      background: linear-gradient(135deg, var(--primary), var(--accent));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .stat-label {
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      font-weight: 800;
      color: var(--text-muted);
    }

    /* Bento Grid Layout Variations */
    .col-span-2 { grid-column: span 2; }
    .row-span-2 { grid-row: span 2; }

    .blog-item {
      display: flex;
      align-items: center;
      gap: 15px;
      padding: 12px;
      border-bottom: 1px solid var(--glass-border);
      transition: background 0.3s;
    }
    .blog-item:last-child { border-bottom: none; }
    .blog-item:hover { background: rgba(0,0,0,0.02); }

    .blog-thumb {
      width: 50px;
      height: 50px;
      border-radius: 10px;
      object-fit: cover;
      background: #eee;
    }

    .performance-badge {
      padding: 4px 12px;
      border-radius: 50px;
      font-size: 0.75rem;
      font-weight: 700;
      background: rgba(99, 102, 241, 0.1);
      color: var(--primary);
    }
  </style>
<meta name="google-site-verification" content="p9EjGKPgnY1TaMyKTTa_UUkRNRVH2oPLpqBWyKQDLk0" />
</head>
<body>
  <div class="mesh-bg"></div>
  <%- include("./partials/navbar") %>

  <main class="container" style="padding: 120px 0;">
    <header style="margin-bottom: 3rem; display: flex; justify-content: space-between; align-items: flex-end;">
      <div>
        <span class="category-badge" style="margin-bottom: 1rem;">Analytics Overview</span>
        <h1 class="gradient-text" style="font-size: 3.5rem; font-weight: 800; letter-spacing: -0.04em; margin: 0;">Creator Hub.</h1>
      </div>
      <a href="/blogs/new" class="btn-primary" style="padding: 18px 32px; text-decoration: none;">New Story &plus;</a>
    </header>

    <div class="dashboard-grid">
      <!-- Main Stats -->
      <div class="bento-card">
        <span class="stat-val"><%= stats.totalBlogs %></span>
        <span class="stat-label">Stories Published</span>
      </div>
      <div class="bento-card">
        <span class="stat-val"><%= stats.totalLikes %></span>
        <span class="stat-label">Total Applause</span>
      </div>
      <div class="bento-card">
        <span class="stat-val"><%= stats.totalComments %></span>
        <span class="stat-label">Conversations</span>
      </div>
      <div class="bento-card">
        <span class="stat-val"><%= stats.avgEngagement %></span>
        <span class="stat-label">Avg Engagement</span>
      </div>

      <!-- Top Performing Content -->
      <div class="bento-card col-span-2 row-span-2">
         <h3 style="font-weight: 800; margin-bottom: 1.5rem; font-size: 1.5rem;">Top Performance</h3>
         <div style="display: flex; flex-direction: column; gap: 10px;">
           <% topBlogs.forEach(blog => { %>
             <div class="blog-item" style="padding: 1.5rem; background: rgba(255,255,255,0.4); border-radius: 15px; border: 1px solid var(--glass-border);">
               <div style="flex: 1;">
                 <h4 style="margin: 0 0 5px 0; font-size: 1.1rem;"><%= blog.title %></h4>
                 <div style="display: flex; gap: 15px; align-items: center;">
                   <span style="font-size: 0.8rem; color: var(--text-muted);">❤️ <%= blog.likes %></span>
                   <span style="font-size: 0.8rem; color: var(--text-muted);">💬 <%= blog.comments %></span>
                   <span class="performance-badge"><%= ((blog.engagement / stats.totalBlogs) * 10).toFixed(0) %>% Power</span>
                 </div>
               </div>
               <a href="/blogs/<%= blog._id %>" style="color: var(--primary); font-weight: 800; text-decoration: none;">View &rarr;</a>
             </div>
           <% }) %>
           <% if (topBlogs.length === 0) { %>
             <p style="color: var(--text-muted); font-style: italic; text-align: center; padding: 2rem;">Publish more to see analytics!</p>
           <% } %>
         </div>
      </div>

      <!-- Recent Activity Feed -->
      <div class="bento-card col-span-2 row-span-2" style="justify-content: flex-start;">
        <h3 style="font-weight: 800; margin-bottom: 1.5rem; font-size: 1.5rem;">Content Repository</h3>
        <div style="max-height: 400px; overflow-y: auto; padding-right: 10px;">
          <% blogs.forEach(blog => { %>
            <div class="blog-item">
              <img src="<%= blog.images && blog.images[0] ? (blog.images[0].startsWith('http') ? blog.images[0] : '/uploads/' + blog.images[0]) : '/favicon.ico' %>" class="blog-thumb" alt="">
              <div style="flex: 1;">
                <h5 style="margin: 0; font-size: 0.95rem; font-weight: 700;"><%= blog.title %></h5>
                <p style="margin: 0; font-size: 0.75rem; color: var(--text-muted);"><%= new Date(blog.createdAt).toLocaleDateString() %> • <%= blog.category %></p>
              </div>
              <div style="display: flex; gap: 10px;">
                <a href="/blogs/<%= blog._id %>/edit" title="Edit" style="text-decoration: none; font-size: 1.2rem;">✏️</a>
                <form action="/blogs/<%= blog._id %>/delete" method="POST" style="display: inline;" onsubmit="return confirm('Archive this story permanently?')">
                  <button type="submit" style="background: none; border: none; cursor: pointer; font-size: 1.2rem;">🗑️</button>
                </form>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    </div>
  </main>

</body>
</html>
