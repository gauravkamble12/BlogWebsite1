<nav>
  <div class="logo">
    <a href="/" class="gradient-text">GK BLOG.</a>
  </div>

  <div style="display: flex; align-items: center; gap: 20px;">
    <!-- Search Trigger (Mobile Only) -->
    <button id="mobile-search-trigger" style="display: none; background: transparent; border: none; font-size: 1.2rem; cursor: pointer; color: var(--text-main);">🔍</button>

    <div class="nav-links">
    <form action="/" method="GET" style="position: relative; display: flex; align-items: center;">
      <input type="text" name="search" id="blogSearch" placeholder="Find stories..." value="<%= typeof search !== 'undefined' ? search : '' %>"
        style="background: rgba(0,0,0,0.03); border: 1px solid var(--glass-border); padding: 10px 20px; border-radius: 50px; color: var(--text-main); width: 240px; outline: none; transition: all 0.3s; font-size: 0.9rem;">
      <button type="submit" style="position: absolute; right: 15px; background: none; border: none; cursor: pointer; color: var(--text-muted);">🔍</button>
    </form>
    
    <% if (!user) { %>
      <a href="/login">Login</a>
      <a href="/register" class="btn-primary" style="padding: 10px 24px; text-decoration: none;">Join</a>
    <% } else { %>
      <a href="/dashboard" style="font-weight: 700; color: var(--primary);">Dashboard</a>
      <a href="/blogs/new">Write</a>
      <div style="display: flex; align-items: center; gap: 12px; margin-left: 20px;">
        <a href="/profile" style="display: flex; align-items: center; gap: 10px; text-decoration: none;">
          <div style="width: 36px; height: 36px; border-radius: 50%; background: var(--primary); display: flex; align-items: center; justify-content: center; color: white; font-weight: 800; font-size: 0.8rem; border: 2px solid var(--glass-border); overflow: hidden;">
            <% if (user.profilePicture) { %>
              <img src="<%= user.profilePicture.startsWith('http') ? user.profilePicture : '/uploads/profiles/' + user.profilePicture %>" style="width: 100%; height: 100%; object-fit: cover;">
            <% } else { %>
              <%= user.name.charAt(0).toUpperCase() %>
            <% } %>
          </div>
          <span style="color: var(--text-main); font-weight: 600; font-size: 0.9rem;"><%= user.name.split(' ')[0] %></span>
        </a>
        <a href="/logout" style="color: var(--accent); font-size: 0.85rem; font-weight: 700;">Sign Out</a>
      </div>
    <% } %>
    
      <button id="theme-toggle" class="nav-icon-btn">
        <svg id="theme-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5"></circle>
          <line x1="12" y1="1" x2="12" y2="3"></line>
          <line x1="12" y1="21" x2="12" y2="23"></line>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
          <line x1="1" y1="12" x2="3" y2="12"></line>
          <line x1="21" y1="12" x2="23" y2="12"></line>
          <line x1="4.22" y1="17.78" x2="5.64" y2="16.36"></line>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
        </svg>
      </button>

      <button onclick="toggleBell()" class="nav-icon-btn" style="position: relative;">
        🔔
        <div id="notif-dot" style="position: absolute; top: 10px; right: 10px; width: 8px; height: 8px; background: var(--accent); border-radius: 50%; display: none; border: 2px solid white;"></div>
      </button>
    </div>

    <!-- Hamburger Menu -->
    <div class="hamburger" id="hamburger">
      <span></span>
      <span></span>
      <span></span>
    </div>
  </div>
</nav>

<!-- Mobile Overlay -->
<div class="mobile-overlay" id="mobileOverlay">
  <form action="/" method="GET" style="width: 80%; margin-bottom: 40px;">
    <input type="text" name="search" placeholder="Search Vitreous..." 
      style="width: 100%; background: rgba(0,0,0,0.05); border: 1px solid var(--glass-border); padding: 18px 24px; border-radius: 50px; color: var(--text-main); font-size: 1.1rem; outline: none;">
  </form>
  
  <a href="/" class="mobile-nav-link">Home</a>
  <% if (!user) { %>
    <a href="/login" class="mobile-nav-link">Login</a>
    <a href="/register" class="mobile-nav-link" style="color: var(--primary);">Join Now</a>
  <% } else { %>
    <a href="/dashboard" class="mobile-nav-link">Dashboard</a>
    <a href="/blogs/new" class="mobile-nav-link">Write Story</a>
    <a href="/profile" class="mobile-nav-link">My Profile</a>
    <a href="/logout" class="mobile-nav-link" style="color: var(--accent);">Sign Out</a>
  <% } %>
</div>

<div id="bell-menu" style="position: fixed; top: 90px; right: 6%; width: 300px; background: white; border: 1px solid var(--glass-border); border-radius: var(--radius-md); display: none; z-index: 1001; padding: 20px; box-shadow: var(--shadow-lg);">
  <h4 style="margin-bottom: 15px; font-weight: 800;">Recent Notifications</h4>
  <div id="notifications-list" style="display: flex; flex-direction: column; gap: 12px;">
    <% if (typeof notifications !== 'undefined' && notifications.length > 0) { %>
      <% notifications.forEach(n => { %>
        <a href="<%= n.link %>" style="padding: 12px; background: rgba(0,0,0,0.03); border-radius: var(--radius-sm); text-decoration: none; color: var(--text-muted); font-size: 0.85rem; transition: all 0.2s;">
          <%= n.message %>
        </a>
      <% }) %>
    <% } else { %>
      <p style="color: var(--text-muted); font-size: 0.85rem; font-style: italic;">All caught up!</p>
    <% } %>
  </div>
</div>

<script>
  function toggleBell() {
    const menu = document.getElementById('bell-menu');
    menu.style.display = menu.style.display === 'none' ? 'block' : 'none';
  }

  // Socket and notification handling
  document.addEventListener("DOMContentLoaded", () => {
    const userId = "<%= user ? user._id : '' %>";
    if (userId) {
      const socket = io();
      socket.emit("join", userId);
      socket.on("notification", (notification) => {
        document.getElementById('notif-dot').style.display = 'block';
        // toast logic here...
      });
    }
    
    // Search highlight (Desktop)
    const searchInput = document.getElementById('blogSearch');
    if (searchInput) {
      searchInput.addEventListener('focus', () => {
        searchInput.style.width = '300px';
        searchInput.style.borderColor = 'var(--primary)';
      });
      searchInput.addEventListener('blur', () => {
        searchInput.style.width = '240px';
        searchInput.style.borderColor = 'var(--glass-border)';
      });
    }

    // Mobile Navigation Toggle
    const hamburger = document.getElementById('hamburger');
    const mobileOverlay = document.getElementById('mobileOverlay');
    const mobileSearchTrigger = document.getElementById('mobile-search-trigger');
    const mobileSearchInput = mobileOverlay.querySelector('input[name="search"]');
    
    const toggleMenu = () => {
      hamburger.classList.toggle('active');
      mobileOverlay.classList.toggle('active');
      document.body.style.overflow = mobileOverlay.classList.contains('active') ? 'hidden' : 'auto';
    };

    hamburger.addEventListener('click', toggleMenu);
    
    mobileSearchTrigger.addEventListener('click', () => {
      if (!mobileOverlay.classList.contains('active')) {
        toggleMenu();
      }
      setTimeout(() => mobileSearchInput.focus(), 300);
    });
  });
</script>

<style>
  .nav-icon-btn {
    background: transparent;
    border: none;
    font-size: 1.25rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    transition: all 0.3s;
    color: var(--text-main);
  }
  .nav-icon-btn:hover { background: rgba(0,0,0,0.05); }

  @media (max-width: 1024px) {
    #mobile-search-trigger { display: block !important; }
  }
</style>