<!DOCTYPE html>
<html lang="en">
<head>
  <%- include("../partials/head") %>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <style>
    body {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }
    .auth-glass-card {
      width: 100%;
      max-width: 440px;
      padding: 3.5rem;
      background: white;
      border: 1px solid var(--glass-border);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-lg);
      animation: slideUp 0.8s cubic-bezier(0.23, 1, 0.32, 1);
    }
    .form-group { margin-bottom: 1.5rem; }
    .form-group label {
      display: block;
      font-weight: 800;
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-bottom: 0.5rem;
      color: var(--text-muted);
    }
    .form-group input {
      width: 100%;
      padding: 1rem 1.25rem;
      border-radius: var(--radius-sm);
      border: 1px solid var(--glass-border);
      background: rgba(0, 0, 0, 0.02);
      color: var(--text-main);
      font-size: 1rem;
      outline: none;
      transition: all 0.3s;
    }
    .form-group input:focus {
      border-color: var(--primary);
      background: rgba(255, 255, 255, 0.08);
      box-shadow: 0 0 15px rgba(99, 102, 241, 0.2);
    }
    @media (max-width: 480px) {
      .auth-glass-card { padding: 2rem 1.5rem; }
      .logo a { font-size: 2rem !important; }
    }
    .step { display: none; }
    .step.active { display: block; animation: fadeIn 0.5s ease; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
  </style>
</head>
<body>
  <div class="mesh-bg"></div>

  <div class="auth-glass-card">
    <header style="text-align: center; margin-bottom: 2.5rem;">
      <div class="logo" style="margin-bottom: 1rem;"><a href="/" class="gradient-text" style="font-size: 2.5rem;">GK.</a></div>
      <h2 style="font-size: 1.75rem; font-weight: 800; letter-spacing: -0.02em;">Reset Password</h2>
      <p style="color: var(--text-muted); font-size: 0.95rem; margin-top: 5px;">Follow the steps to regain access.</p>
    </header>

    <!-- STEP 1: ENTER EMAIL -->
    <div id="step-1" class="step active">
      <form id="form-step-1">
        <div class="form-group">
          <label>Email Address</label>
          <input type="email" name="email" id="email" placeholder="name@email.com" required>
        </div>
        <button type="submit" class="btn-primary" style="width: 100%; margin-top: 1rem; padding: 16px;">Send Reset PIN</button>
      </form>
    </div>

    <!-- STEP 2: ENTER PIN -->
    <div id="step-2" class="step">
      <form id="form-step-2">
        <div class="form-group">
          <label>6-Digit PIN</label>
          <input type="text" name="otp" id="otp" placeholder="123456" maxlength="6" pattern="\d{6}" required style="text-align: center; font-size: 24px; letter-spacing: 12px; font-weight: 800;">
        </div>
        <button type="submit" class="btn-primary" style="width: 100%; margin-top: 1rem; padding: 16px;">Verify PIN</button>
        <p style="text-align: center; margin-top: 15px; font-size: 0.85rem; color: var(--text-muted);">
          Didn't get a code? <a href="#" id="resend-link" style="color: var(--primary); text-decoration: none;">Resend</a>
        </p>
    </div>

    <!-- STEP 3: NEW PASSWORD -->
    <div id="step-3" class="step">
      <form id="form-step-3">
        <div class="form-group">
          <label>New Password</label>
          <input type="password" name="password" id="password" placeholder="••••••••">
        </div>
        <div class="form-group">
          <label>Confirm New Password</label>
          <input type="password" name="confirmPassword" id="confirmPassword" placeholder="••••••••">
        </div>
        <button type="submit" class="btn-primary" style="width: 100%; margin-top: 1rem; padding: 16px;">Update Password</button>
      </form>
    </div>

    <footer style="margin-top: 2rem; text-align: center; color: var(--text-muted); font-size: 0.9rem;">
      Remembered your password? <a href="/login" style="color: var(--primary); font-weight: 700; text-decoration: none;">Sign In &rarr;</a>
    </footer>
  </div>

  <script>
    let currentEmail = '';
    let currentOTP = '';

    const showStep = (num) => {
      document.querySelectorAll('.step').forEach(s => s.classList.remove('active'));
      document.getElementById(`step-${num}`).classList.add('active');
    };

    // Handle Step 1: Send PIN
    document.getElementById('form-step-1').addEventListener('submit', async (e) => {
      e.preventDefault();
      currentEmail = document.getElementById('email').value;
      
      try {
        const res = await fetch('/forgot-password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: currentEmail })
        });
        const result = await res.json();
        
        if (res.ok) {
          Swal.fire({ icon: 'success', title: 'PIN Sent!', text: 'Please check your email.', toast: true, position: 'top-end', showConfirmButton: false, timer: 3000 });
          showStep(2);
        } else {
          Swal.fire({ icon: 'error', title: 'Error', text: result.error, toast: true, position: 'top-end', showConfirmButton: false, timer: 3000 });
        }
      } catch (err) {
        console.error(err);
      }
    });

    // Handle Step 2: Verify PIN
    document.getElementById('form-step-2').addEventListener('submit', async (e) => {
      e.preventDefault();
      currentOTP = document.getElementById('otp').value;

      try {
        const res = await fetch('/verify-otp', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: currentEmail, otp: currentOTP })
        });
        const result = await res.json();

        if (res.ok) {
          Swal.fire({ icon: 'success', title: 'PIN Verified!', text: 'Now create your new password.', toast: true, position: 'top-end', showConfirmButton: false, timer: 3000 });
          showStep(3);
        } else {
          Swal.fire({ icon: 'error', title: 'Invalid PIN', text: result.error, toast: true, position: 'top-end', showConfirmButton: false, timer: 3000 });
        }
      } catch (err) {
        console.error(err);
      }
    });

    // Handle Step 3: Reset Password
    document.getElementById('form-step-3').addEventListener('submit', async (e) => {
      e.preventDefault();
      const password = document.getElementById('password').value;
      const confirmPassword = document.getElementById('confirmPassword').value;

      if (password !== confirmPassword) {
        return Swal.fire({ icon: 'warning', title: 'Mismatch', text: 'Passwords do not match.', toast: true, position: 'top-end', showConfirmButton: false, timer: 3000 });
      }

      try {
        const res = await fetch('/reset-password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: currentEmail, otp: currentOTP, password })
        });
        const result = await res.json();

        if (res.ok) {
          Swal.fire({ icon: 'success', title: 'Success!', text: 'Redirecting to login...', showConfirmButton: false, timer: 2000 }).then(() => {
            window.location.href = '/login';
          });
        } else {
          Swal.fire({ icon: 'error', title: 'Failed', text: result.error, toast: true, position: 'top-end', showConfirmButton: false, timer: 3000 });
        }
      } catch (err) {
        console.error(err);
      }
    });

    // Resend Logic
    document.getElementById('resend-link').addEventListener('click', (e) => {
      e.preventDefault();
      document.getElementById('form-step-1').dispatchEvent(new Event('submit'));
    });
  </script>
</body>
</html>
