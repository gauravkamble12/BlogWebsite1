<!DOCTYPE html>
<html lang="en">
<head>
  <%- include("partials/head") %>
  <style>
    .profile-header-premium {
      padding: 120px 0 80px;
      text-align: center;
      position: relative;
    }
    .profile-avatar-giant {
      width: 180px; height: 180px;
      border-radius: 50%;
      border: 1px solid var(--glass-border);
      background: white;
      margin: 0 auto 30px;
      overflow: hidden;
      display: flex; align-items: center; justify-content: center;
      box-shadow: var(--shadow-lg);
    }
    .profile-avatar-giant img { width: 100%; height: 100%; object-fit: cover; }
    
    .stats-pill {
      display: inline-flex;
      gap: 32px;
      background: #f8fafc;
      padding: 16px 40px;
      border-radius: 50px;
      border: 1px solid var(--glass-border);
      margin-top: 30px;
      box-shadow: var(--shadow-sm);
    }
    .stat-item { text-align: center; }
    .stat-val { font-size: 1.25rem; font-weight: 800; color: var(--text-main); }
    .stat-lbl { font-size: 0.75rem; text-transform: uppercase; color: var(--text-muted); font-weight: 700; }
  </style>
</head>
<body>
  <div class="mesh-bg"></div>
  <%- include("partials/navbar") %>

  <main class="container">
    <section class="profile-header-premium animate-up">
      <div class="profile-avatar-giant">
        <% if (profileUser.profilePicture) { %>
          <img src="<%= profileUser.profilePicture.startsWith('http') ? profileUser.profilePicture : '/uploads/profiles/' + profileUser.profilePicture %>">
        <% } else { %>
          <div style="font-size: 4rem; font-weight: 800;"><%= profileUser.name.charAt(0).toUpperCase() %></div>
        <% } %>
      </div>
      <h1 class="gradient-text" style="font-size: 4rem; font-weight: 800; letter-spacing: -0.04em;"><%= profileUser.name %></h1>
      <p style="color: var(--text-muted); font-size: 1.1rem; letter-spacing: 0.1em; text-transform: uppercase; font-weight: 600; margin-top: 8px;">
        <%= profileUser.profession || 'Inspiring Creator' %>
      </p>

      <div class="stats-pill">
        <div class="stat-item">
          <div class="stat-val"><%= blogs.length %></div>
          <div class="stat-lbl">Stories</div>
        </div>
        <div class="stat-item">
          <div class="stat-val"><%= (typeof followers !== 'undefined' ? followers : 0) %></div>
          <div class="stat-lbl">Followers</div>
        </div>
      </div>

      <% if (user && user._id.toString() === profileUser._id.toString()) { %>
        <div style="margin-top: 40px;">
          <a href="/profile/edit" class="btn-primary" style="padding: 12px 40px; text-decoration: none; background: transparent; border: 2px solid var(--primary); color: var(--primary);">Edit Profile</a>
        </div>
      <% } %>

      <% if (user && user._id.toString() !== profileUser._id.toString()) { %>
        <div style="margin-top: 40px;">
          <form action="/follow/<%= profileUser._id %>" method="POST">
            <button type="submit" class="btn-primary" style="padding: 12px 40px;">Follow Perspective</button>
          </form>
        </div>
      <% } %>
    </section>

    <section style="margin-top: 60px;">
      <h2 style="font-size: 2rem; font-weight: 800; margin-bottom: 40px; text-align: center;">Curated Bibliography</h2>
      
      <div class="editorial-grid">
        <% if (blogs.length === 0) { %>
          <div style="grid-column: span 12; padding: 100px; text-align: center; background: var(--surface); border-radius: var(--radius-md); border: 1px dashed var(--glass-border);">
            <p style="color: var(--text-muted); font-style: italic;">No stories have been published to this catalog yet.</p>
          </div>
        <% } else { %>
          <% blogs.forEach((blog, index) => { %>
            <div class="story-card animate-up" style="grid-column: span 4; animation-delay: <%= index * 0.1 %>s;">
              <div style="height: 200px;">
                <% if (blog.images && blog.images.length > 0) { %>
                  <img src="/uploads/<%= blog.images[0] %>" style="width: 100%; height: 100%; object-fit: cover;">
                <% } else { %>
                  <div style="width: 100%; height: 100%; background: #0f172a; display: flex; align-items: center; justify-content: center;">✨</div>
                <% } %>
              </div>
              <div style="padding: 24px; flex: 1; display: flex; flex-direction: column; gap: 12px;">
                <span style="font-size: 0.75rem; font-weight: 800; color: var(--primary); text-transform: uppercase;"><%= blog.category %></span>
                <h3 style="font-size: 1.4rem; font-weight: 800; line-height: 1.2;">
                  <a href="/blogs/<%= blog._id %>" style="color: inherit; text-decoration: none;"><%= blog.title %></a>
                </h3>
                <div style="margin-top: auto; padding-top: 16px; border-top: 1px solid var(--glass-border); font-size: 0.8rem; color: var(--text-muted); font-weight: 600;">
                  <%= new Date(blog.createdAt).toLocaleDateString() %>
                </div>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>
    </section>
  </main>

  <footer style="margin-top: 120px; padding: 80px 0; border-top: 1px solid var(--glass-border); text-align: center;">
     <div class="logo"><a href="/" class="gradient-text">GK.</a></div>
     <p style="color: var(--text-muted); margin-top: 20px;">© 2026 Crafted for the Modern Reader.</p>
  </footer>
</body>
</html>
